{
  "manifest_version": 3,
  "name": "ScamShield — Phishing Detector",
  "version": "1.0.0",
  "description": "Real-time AI-powered phishing URL detection. Stay safe online.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ScamShield",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
